@model Mobile_Store.Models.Order
@{
    ViewData["Title"] = "Order Success";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="admin-card text-center py-5">
                <div class="mb-4">
                    <i class="fa-solid fa-circle-check fa-4x text-success"></i>
                </div>
                <h2 class="mb-3">Order Placed Successfully!</h2>
                <p class="text-muted mb-4">Thank you for your purchase. Your order has been confirmed.</p>
                
                <div class="row justify-content-center mb-4">
                    <div class="col-md-10">
                        <div class="admin-card p-4" style="background-color:#f8f9fa;">
                            <h5 class="mb-4 text-start">Order Details</h5>
                            
                            <div class="row text-start">
                                <div class="col-md-6 mb-3">
                                    <p class="mb-2"><strong>Order Number:</strong></p>
                                    <p class="text-primary">#@Model.Id</p>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <p class="mb-2"><strong>Order Date:</strong></p>
                                    <p>@Model.OrderDate.ToLocalTime().ToString("MMMM dd, yyyy hh:mm tt")</p>
                                </div>
                            </div>

                            <div class="row text-start">
                                <div class="col-md-6 mb-3">
                                    <p class="mb-2"><strong>Total Amount:</strong></p>
                                    <p class="h5 text-success">Rs @Model.TotalAmount.ToString("0.00")</p>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <p class="mb-2"><strong>Order Status:</strong></p>
                                    <span class="badge bg-warning">@Model.Status</span>
                                </div>
                            </div>

                            <hr />

                            <div class="row text-start">
                                <div class="col-md-6 mb-3">
                                    <p class="mb-2"><strong>Payment Method:</strong></p>
                                    <p>
                                        @if (Model.PaymentMethod == "Cash on Delivery")
                                        {
                                            <i class="fa-solid fa-hand-holding-dollar me-2"></i>
                                            <span>@Model.PaymentMethod</span>
                                        }
                                        else
                                        {
                                            <i class="fa-solid fa-credit-card me-2"></i>
                                            <span>@Model.PaymentMethod</span>
                                        }
                                    </p>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <p class="mb-2"><strong>Payment Status:</strong></p>
                                    <span class="badge bg-@(Model.PaymentStatus == "Paid" ? "success" : "warning")">
                                        @Model.PaymentStatus
                                    </span>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.TransactionId))
                            {
                                <div class="row text-start">
                                    <div class="col-12 mb-3">
                                        <p class="mb-2"><strong>Transaction ID:</strong></p>
                                        <p class="text-muted small">@Model.TransactionId</p>
                                    </div>
                                </div>
                            }

                            <hr />

                            <div class="row text-start">
                                <div class="col-md-6 mb-3">
                                    <p class="mb-2"><strong>Customer Name:</strong></p>
                                    <p>@Model.CustomerName</p>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <p class="mb-2"><strong>Phone Number:</strong></p>
                                    <p>@Model.CustomerPhone</p>
                                </div>
                            </div>

                            <div class="row text-start">
                                <div class="col-12 mb-3">
                                    <p class="mb-2"><strong>Shipping Address:</strong></p>
                                    <p class="text-muted">@Model.ShippingAddress</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @if (Model.PaymentMethod == "Cash on Delivery")
                {
                    <div class="alert alert-info">
                        <i class="fa-solid fa-info-circle me-2"></i>
                        <strong>Payment on Delivery:</strong> Please keep Rs @Model.TotalAmount.ToString("0.00") ready for payment when your order arrives.
                    </div>
                }
                else
                {
                    <div class="alert alert-success">
                        <i class="fa-solid fa-check-circle me-2"></i>
                        <strong>Payment Successful:</strong> Your payment has been processed successfully.
                    </div>
                }

                <div class="d-flex gap-3 justify-content-center flex-wrap">
                    <a asp-controller="Profile" asp-action="Orders" class="btn btn-primary">
                        <i class="fa-solid fa-receipt me-2"></i>View My Orders
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
                        <i class="fa-solid fa-store me-2"></i>Continue Shopping
                    </a>
                    <button onclick="window.print()" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-print me-2"></i>Print Order
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        .btn, nav, footer { display: none !important; }
    }
</style>
