@model Mobile_Store.Models.Order
@{
    ViewData["Title"] = "Order Success";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="admin-card text-center py-5">
                <div class="mb-4">
                    <i class="fa-solid fa-circle-check fa-4x text-success"></i>
                </div>
                <h2 class="mb-3">Order Placed Successfully!</h2>
                <p class="text-muted mb-4">Thank you for your purchase. Your order has been confirmed.</p>
                
                <div class="mb-4">
                    <div class="admin-card d-inline-block p-4" style="background-color:#f8f9fa;">
                        <h5 class="mb-3">Order Details</h5>
                        <p class="mb-2"><strong>Order Number:</strong> #@Model.Id</p>
                        <p class="mb-2"><strong>Order Date:</strong> @Model.OrderDate.ToLocalTime().ToString("MMMM dd, yyyy hh:mm tt")</p>
                        <p class="mb-2"><strong>Total Amount:</strong> <span class="h5 text-success">$@Model.TotalAmount.ToString("0.00")</span></p>
                        <p class="mb-0"><strong>Status:</strong> <span class="badge bg-warning">@Model.Status</span></p>
                    </div>
                </div>

                <div class="d-flex gap-3 justify-content-center">
                    <a asp-controller="Checkout" asp-action="Orders" class="btn btn-primary">
                        <i class="fa-solid fa-receipt me-2"></i>View My Orders
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
                        <i class="fa-solid fa-store me-2"></i>Continue Shopping
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
