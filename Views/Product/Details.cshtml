@model Mobile_Store.ViewModels.ProductReviewsViewModel
@inject UserManager<ApplicationUser> _userManager
@{
    ViewData["Title"] = Model.Product.Name;
}

<div class="container my-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index">Products</a></li>
            <li class="breadcrumb-item active">@Model.Product.Name</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="product-card">
                <img src="@(string.IsNullOrEmpty(Model.Product.ImageUrl) ? "/images/placeholder.png" : Model.Product.ImageUrl)" 
                     alt="@Model.Product.Name" class="product-detail-image" />
            </div>
        </div>

        <div class="col-md-7">
            <div class="admin-card">
                <h2 class="mb-3">@Model.Product.Name</h2>
                
                @if (Model.Product.Category != null)
                {
                    <p class="text-muted mb-3">
                        <i class="fa-solid fa-tag me-2"></i>
                        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@Model.Product.CategoryId">@Model.Product.Category.Name</a>
                    </p>
                }

                <!-- Star Rating Display -->
                <div class="mb-3">
                    @if (Model.Product.ReviewCount > 0)
                    {
                        <div class="d-flex align-items-center">
                            <div class="star-rating me-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Floor(Model.AverageRating))
                                    {
                                        <i class="fa-solid fa-star text-warning"></i>
                                    }
                                    else if (i == Math.Ceiling(Model.AverageRating) && Model.AverageRating % 1 >= 0.5)
                                    {
                                        <i class="fa-solid fa-star-half-stroke text-warning"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-regular fa-star text-warning"></i>
                                    }
                                }
                            </div>
                            <span class="fw-bold me-2">@Model.AverageRating.ToString("0.0")</span>
                            <span class="text-muted">(@Model.Product.ReviewCount @(Model.Product.ReviewCount == 1 ? "review" : "reviews"))</span>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">
                            <i class="fa-regular fa-star"></i>
                            No reviews yet - Be the first to review!
                        </div>
                    }
                </div>

                <h3 class="price mb-4">Rs @Model.Product.Price.ToString("0.00")</h3>

                <div class="mb-4">
                    <h5>Description</h5>
                    <p>@Model.Product.Description</p>
                </div>

                <form asp-controller="Cart" asp-action="Add" method="post" class="mb-3">
                    <input type="hidden" name="productId" value="@Model.Product.Id" />
                    <div class="row align-items-end">
                        <div class="col-auto">
                            <label class="form-label">Quantity</label>
                            <input type="number" name="quantity" value="1" min="1" max="99" class="form-control" style="width:100px;" />
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-success">
                                <i class="fa-solid fa-cart-plus me-2"></i>Add to Cart
                            </button>
                        </div>
                    </div>
                </form>

                <div class="d-flex gap-2">
                    <form asp-controller="Wishlist" asp-action="Add" method="post" class="d-inline">
                        <input type="hidden" name="productId" value="@Model.Product.Id" />
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="fa-regular fa-heart me-2"></i>Add to Wishlist
                        </button>
                    </form>

                    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-arrow-left me-2"></i>Back to Products
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Reviews Section -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="admin-card">
                <h3 class="mb-4">
                    <i class="fa-solid fa-star me-2"></i>Customer Reviews
                    @if (Model.Product.ReviewCount > 0)
                    {
                        <span class="badge bg-primary ms-2">@Model.Product.ReviewCount</span>
                    }
                </h3>

                <!-- Rating Summary -->
                @if (Model.Product.ReviewCount > 0)
                {
                    <div class="row mb-4">
                        <div class="col-md-4 text-center">
                            <h1 class="display-3 mb-0">@Model.AverageRating.ToString("0.0")</h1>
                            <div class="star-rating-large mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Floor(Model.AverageRating))
                                    {
                                        <i class="fa-solid fa-star text-warning"></i>
                                    }
                                    else if (i == Math.Ceiling(Model.AverageRating) && Model.AverageRating % 1 >= 0.5)
                                    {
                                        <i class="fa-solid fa-star-half-stroke text-warning"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-regular fa-star text-warning"></i>
                                    }
                                }
                            </div>
                            <p class="text-muted mb-0">Based on @Model.Product.ReviewCount @(Model.Product.ReviewCount == 1 ? "review" : "reviews")</p>
                        </div>
                        <div class="col-md-8">
                            <!-- Rating Distribution -->
                            @for (int star = 5; star >= 1; star--)
                            {
                                var count = Model.RatingDistribution.ContainsKey(star) ? Model.RatingDistribution[star] : 0;
                                var percentage = Model.Product.ReviewCount > 0 ? (count * 100.0 / Model.Product.ReviewCount) : 0;
                                
                                <div class="d-flex align-items-center mb-2">
                                    <span class="me-2" style="min-width:60px;">@star <i class="fa-solid fa-star text-warning small"></i></span>
                                    <div class="progress flex-grow-1 me-3" style="height:10px;">
                                        <div class="progress-bar bg-warning" role="progressbar" 
                                             style="width: @percentage%" 
                                             aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <span class="text-muted" style="min-width:50px;">@count</span>
                                </div>
                            }
                        </div>
                    </div>
                    <hr />
                }

                <!-- Write Review Form -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    if (!Model.UserHasReviewed)
                    {
                        <div class="mb-4 p-4 bg-light rounded">
                            <h5 class="mb-3">
                                <i class="fa-solid fa-pen-to-square me-2"></i>Write a Review
                                @if (Model.UserHasOrdered)
                                {
                                    <span class="badge bg-success ms-2"><i class="fa-solid fa-check me-1"></i>Verified Purchase</span>
                                }
                            </h5>
                            
                            <form asp-controller="Review" asp-action="Add" method="post">
                                <input type="hidden" asp-for="NewReview.ProductId" />
                                
                                <div class="mb-3">
                                    <label class="form-label">Rating *</label>
                                    <div class="star-rating-input">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            var starId = $"star{i}";
                                            <input type="radio" id="@starId" name="NewReview.Rating" value="@i" required />
                                            <label for="@starId"><i class="fa-solid fa-star"></i></label>
                                        }
                                    </div>
                                    <span asp-validation-for="NewReview.Rating" class="text-danger"></span>
                                </div>
                                
                                <div class="mb-3">
                                    <label asp-for="NewReview.Comment" class="form-label">Your Review *</label>
                                    <textarea asp-for="NewReview.Comment" class="form-control" rows="4" 
                                              placeholder="Share your experience with this product..." 
                                              maxlength="1000" required></textarea>
                                    <span asp-validation-for="NewReview.Comment" class="text-danger"></span>
                                    <small class="text-muted">Minimum 10 characters</small>
                                </div>
                                
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa-solid fa-paper-plane me-2"></i>Submit Review
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="fa-solid fa-info-circle me-2"></i>
                            You have already reviewed this product. Thank you for your feedback!
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-warning">
                        <i class="fa-solid fa-sign-in-alt me-2"></i>
                        Please <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="/Product/Details/@Model.Product.Id">login</a> to write a review.
                    </div>
                }

                <!-- Reviews List -->
                @if (Model.Reviews.Any())
                {
                    <h5 class="mb-3 mt-4">Customer Reviews (@Model.Reviews.Count)</h5>
                    
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="review-item mb-3 p-3 border rounded">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <div class="d-flex align-items-center mb-1">
                                        <strong class="me-2">@(review.ReviewerName ?? "Anonymous")</strong>
                                        @if (review.IsVerifiedPurchase)
                                        {
                                            <span class="badge bg-success-subtle text-success">
                                                <i class="fa-solid fa-check me-1"></i>Verified Purchase
                                            </span>
                                        }
                                    </div>
                                    <div class="star-rating-small">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= review.Rating)
                                            {
                                                <i class="fa-solid fa-star text-warning"></i>
                                            }
                                            else
                                            {
                                                <i class="fa-regular fa-star text-warning"></i>
                                            }
                                        }
                                    </div>
                                </div>
                                <div class="text-muted small">
                                    @review.CreatedAt.ToString("MMM dd, yyyy")
                                </div>
                            </div>
                            
                            @if (!string.IsNullOrEmpty(review.Comment))
                            {
                                <p class="mb-0">@review.Comment</p>
                            }

                            @if (User.Identity?.IsAuthenticated == true && review.UserId == _userManager.GetUserId(User))
                            {
                                <div class="mt-2">
                                    <form asp-controller="Review" asp-action="Delete" method="post" class="d-inline" 
                                          onsubmit="return confirm('Are you sure you want to delete your review?')">
                                        <input type="hidden" name="id" value="@review.Id" />
                                        <input type="hidden" name="productId" value="@Model.Product.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fa-solid fa-trash me-1"></i>Delete
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                }
                else if (!User.Identity?.IsAuthenticated == true || Model.UserHasReviewed)
                {
                    <p class="text-muted text-center py-4">
                        <i class="fa-regular fa-comment-dots fa-2x mb-2 d-block"></i>
                        No reviews yet for this product.
                    </p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
