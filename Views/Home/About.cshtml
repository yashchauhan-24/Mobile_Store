@{
    ViewData["Title"] = "About Us";
}

<div class="container my-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="admin-card">
                <h2 class="mb-4">About Mobile_Store</h2>
                
                <p class="lead">Welcome to Mobile_Store, your premier destination for premium mobile devices.</p>
                
                <p>We are dedicated to bringing you the finest selection of mobile technology, carefully curated for elegance, performance, and innovation. Our mission is to provide a seamless shopping experience while offering the latest and greatest in mobile devices.</p>
                
                <h4 class="mt-4 mb-3">Why Choose Us?</h4>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="d-flex">
                            <i class="fa-solid fa-shield-halved fa-2x text-primary me-3"></i>
                            <div>
                                <h6>Authentic Products</h6>
                                <p class="small text-muted">100% genuine products with warranty</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex">
                            <i class="fa-solid fa-truck-fast fa-2x text-primary me-3"></i>
                            <div>
                                <h6>Fast Delivery</h6>
                                <p class="small text-muted">Quick and secure shipping</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex">
                            <i class="fa-solid fa-headset fa-2x text-primary me-3"></i>
                            <div>
                                <h6>24/7 Support</h6>
                                <p class="small text-muted">Always here to help you</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex">
                            <i class="fa-solid fa-rotate-left fa-2x text-primary me-3"></i>
                            <div>
                                <h6>Easy Returns</h6>
                                <p class="small text-muted">Hassle-free return policy</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-center">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-primary">
                        <i class="fa-solid fa-store me-2"></i>Start Shopping
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
