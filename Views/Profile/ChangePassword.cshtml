@model Mobile_Store.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="container my-5">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 mb-4">
            <div class="admin-card">
                <div class="text-center py-3">
                    <div class="mb-3">
                        <i class="fa-solid fa-user-circle fa-4x text-primary"></i>
                    </div>
                    <h5>@User.Identity?.Name</h5>
                    <p class="text-muted small">Customer</p>
                </div>
                <hr>
                <nav class="nav flex-column">
                    <a asp-controller="Profile" asp-action="Index" class="nav-link">
                        <i class="fa-solid fa-user me-2"></i>Profile
                    </a>
                    <a asp-controller="Profile" asp-action="Orders" class="nav-link">
                        <i class="fa-solid fa-receipt me-2"></i>My Orders
                    </a>
                    <a asp-controller="Profile" asp-action="ChangePassword" class="nav-link active">
                        <i class="fa-solid fa-key me-2"></i>Change Password
                    </a>
                    <a asp-controller="Wishlist" asp-action="Index" class="nav-link">
                        <i class="fa-regular fa-heart me-2"></i>Wishlist
                    </a>
                    <hr>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="nav-link text-danger border-0 bg-transparent w-100 text-start">
                            <i class="fa-solid fa-sign-out-alt me-2"></i>Logout
                        </button>
                    </form>
                </nav>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <div class="admin-card">
                <h3 class="mb-4"><i class="fa-solid fa-key me-2"></i>Change Password</h3>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <h6>Please correct the following errors:</h6>
                        <ul class="mb-0">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                <form asp-controller="Profile" asp-action="ChangePassword" method="post">
                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label">Current Password *</label>
                        <input asp-for="CurrentPassword" class="form-control" placeholder="Enter your current password" required />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">New Password *</label>
                        <input asp-for="NewPassword" class="form-control" placeholder="Enter new password (min 6 characters)" required />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        <small class="text-muted">Password must be at least 6 characters long.</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm New Password *</label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Re-enter new password" required />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="alert alert-warning">
                        <i class="fa-solid fa-exclamation-triangle me-2"></i>
                        <strong>Security Tip:</strong> Choose a strong password with a mix of letters, numbers, and symbols.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-check me-2"></i>Change Password
                        </button>
                        <a asp-controller="Profile" asp-action="Index" class="btn btn-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
