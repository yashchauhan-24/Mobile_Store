@model IEnumerable<Mobile_Store.Models.Wishlist>
@{
    ViewData["Title"] = "My Wishlist";
}

<div class="container my-5">
    <h2 class="mb-4"><i class="fa-regular fa-heart me-2"></i>My Wishlist</h2>

    @if (!Model.Any())
    {
        <div class="admin-card text-center py-5">
            <i class="fa-regular fa-heart fa-3x text-muted mb-3"></i>
            <h4>Your wishlist is empty</h4>
            <p class="text-muted">Save your favorite products for later!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
                <i class="fa-solid fa-store me-2"></i>Browse Products
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="product-card h-100">
                        <div class="img-wrap">
                            <img src="@(string.IsNullOrEmpty(item.Product?.ImageUrl) ? "/images/placeholder.png" : item.Product.ImageUrl)" 
                                 alt="@item.Product?.Name" class="card-img-top" />
                        </div>
                        <div class="card-body">
                            <h6 class="card-title">@item.Product?.Name</h6>
                            <p class="small text-muted mb-2">@item.Product?.Category?.Name</p>
                            <div class="price mb-3">$@item.Product?.Price.ToString("0.00")</div>
                            
                            <div class="d-flex gap-2">
                                <form asp-controller="Cart" asp-action="Add" method="post" class="flex-grow-1">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="btn btn-sm btn-primary w-100">
                                        <i class="fa-solid fa-cart-plus me-1"></i>Add to Cart
                                    </button>
                                </form>
                                <form asp-controller="Wishlist" asp-action="Remove" method="post">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
