@model Mobile_Store.Models.MobileAccessory
@{
    ViewData["Title"] = "Delete Mobile Accessory";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-danger"><i class="fa-solid fa-exclamation-triangle me-2"></i>Delete Mobile Accessory</h2>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fa-solid fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="admin-card">
            <div class="alert alert-danger" role="alert">
                <h4 class="alert-heading">
                    <i class="fa-solid fa-exclamation-triangle me-2"></i>
                    Are you sure you want to delete this accessory?
                </h4>
                <p class="mb-0">This action cannot be undone. All data associated with this accessory will be permanently deleted.</p>
            </div>

            <div class="row">
                <div class="col-md-4">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded border" />
                    }
                    else
                    {
                        <div class="text-center p-4 bg-light rounded border">
                            <i class="fa-solid fa-image fa-3x text-muted"></i>
                        </div>
                    }
                </div>
                <div class="col-md-8">
                    <h4 class="mb-3">@Model.Name</h4>

                    <dl class="row">
                        <dt class="col-sm-4">Brand:</dt>
                        <dd class="col-sm-8">@Model.Brand</dd>

                        <dt class="col-sm-4">Category:</dt>
                        <dd class="col-sm-8">
                            @if (Model.Category != null)
                            {
                                <span>@Model.Category.Name</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Price:</dt>
                        <dd class="col-sm-8"><strong class="text-success">Rs @Model.Price.ToString("0.00")</strong></dd>

                        <dt class="col-sm-4">Stock:</dt>
                        <dd class="col-sm-8">@Model.Stock units</dd>

                        @if (!string.IsNullOrEmpty(Model.Color))
                        {
                            <dt class="col-sm-4">Color:</dt>
                            <dd class="col-sm-8">@Model.Color</dd>
                        }

                        @if (!string.IsNullOrEmpty(Model.Compatibility))
                        {
                            <dt class="col-sm-4">Compatibility:</dt>
                            <dd class="col-sm-8">@Model.Compatibility</dd>
                        }

                        <dt class="col-sm-4">Created:</dt>
                        <dd class="col-sm-8">@Model.CreatedAt.ToString("MMM dd, yyyy")</dd>
                    </dl>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="mt-3">
                            <h6 class="text-muted">Description:</h6>
                            <p>@Model.Description</p>
                        </div>
                    }
                </div>
            </div>

            <hr class="my-4" />

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">
                        <i class="fa-solid fa-trash me-2"></i>Yes, Delete Accessory
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fa-solid fa-times me-2"></i>Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
