@model Mobile_Store.Models.MobileAccessory
@{
    ViewData["Title"] = "Edit Mobile Accessory";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fa-solid fa-edit me-2"></i>Edit Mobile Accessory</h2>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fa-solid fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="admin-card">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Brand" class="form-label"></label>
                        <input asp-for="Brand" class="form-control" />
                        <span asp-validation-for="Brand" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Price" class="form-label"></label>
                        <input asp-for="Price" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Stock" class="form-label"></label>
                        <input asp-for="Stock" class="form-control" />
                        <span asp-validation-for="Stock" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="CategoryId" class="form-label"></label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                            <option value="">-- Select Category --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Color" class="form-label"></label>
                        <input asp-for="Color" class="form-control" />
                        <span asp-validation-for="Color" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Compatibility" class="form-label"></label>
                        <input asp-for="Compatibility" class="form-control" />
                        <span asp-validation-for="Compatibility" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mb-2">
                            <label class="form-label">Current Image:</label>
                            <div>
                                <img src="@Model.ImageUrl" alt="@Model.Name" style="max-width:200px;max-height:200px;object-fit:cover;border-radius:4px;" class="border" />
                            </div>
                        </div>
                    }
                    <label for="imageFile" class="form-label">Change Image (Optional)</label>
                    <input type="file" class="form-control" id="imageFile" name="imageFile" accept="image/*" />
                    <small class="form-text text-muted">Leave empty to keep current image</small>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="IsFeatured" class="form-check-input" />
                    <label asp-for="IsFeatured" class="form-check-label"></label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="fa-solid fa-save me-2"></i>Update Accessory
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fa-solid fa-times me-2"></i>Cancel
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger ms-auto">
                        <i class="fa-solid fa-trash me-2"></i>Delete
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-md-4">
        <div class="admin-card">
            <h5 class="mb-3"><i class="fa-solid fa-info-circle me-2"></i>Information</h5>
            <ul class="list-unstyled small">
                <li class="mb-2">
                    <strong>Created:</strong> @Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                </li>
                @if (Model.UpdatedAt.HasValue)
                {
                    <li class="mb-2">
                        <strong>Last Updated:</strong> @Model.UpdatedAt.Value.ToString("MMM dd, yyyy HH:mm")
                    </li>
                }
                <li class="mb-2">
                    <strong>Accessory ID:</strong> #@Model.Id
                </li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
