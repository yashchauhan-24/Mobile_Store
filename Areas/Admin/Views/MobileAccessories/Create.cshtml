@model Mobile_Store.Models.MobileAccessory
@{
    ViewData["Title"] = "Add Mobile Accessory";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fa-solid fa-plus-circle me-2"></i>Add New Mobile Accessory</h2>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fa-solid fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="admin-card">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="Enter accessory name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Brand" class="form-label"></label>
                        <input asp-for="Brand" class="form-control" placeholder="Enter brand name" />
                        <span asp-validation-for="Brand" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Price" class="form-label"></label>
                        <input asp-for="Price" class="form-control" placeholder="0.00" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Stock" class="form-label"></label>
                        <input asp-for="Stock" class="form-control" placeholder="0" />
                        <span asp-validation-for="Stock" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="CategoryId" class="form-label"></label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                            <option value="">-- Select Category --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Color" class="form-label"></label>
                        <input asp-for="Color" class="form-control" placeholder="e.g., Black, White, Blue" />
                        <span asp-validation-for="Color" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Compatibility" class="form-label"></label>
                        <input asp-for="Compatibility" class="form-control" placeholder="e.g., iPhone 14, Samsung Galaxy S23" />
                        <span asp-validation-for="Compatibility" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter detailed description"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label for="imageFile" class="form-label">Accessory Image</label>
                    <input type="file" class="form-control" id="imageFile" name="imageFile" accept="image/*" />
                    <small class="form-text text-muted">Upload an image (JPG, PNG, GIF). Max size: 5MB</small>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="IsFeatured" class="form-check-input" />
                    <label asp-for="IsFeatured" class="form-check-label"></label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="fa-solid fa-check me-2"></i>Create Accessory
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fa-solid fa-times me-2"></i>Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-md-4">
        <div class="admin-card">
            <h5 class="mb-3"><i class="fa-solid fa-info-circle me-2"></i>Tips</h5>
            <ul class="list-unstyled">
                <li class="mb-2">
                    <i class="fa-solid fa-check text-success me-2"></i>
                    Use clear, descriptive names
                </li>
                <li class="mb-2">
                    <i class="fa-solid fa-check text-success me-2"></i>
                    Add high-quality images
                </li>
                <li class="mb-2">
                    <i class="fa-solid fa-check text-success me-2"></i>
                    Specify compatibility details
                </li>
                <li class="mb-2">
                    <i class="fa-solid fa-check text-success me-2"></i>
                    Set accurate stock quantities
                </li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
