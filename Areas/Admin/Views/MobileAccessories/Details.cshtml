@model Mobile_Store.Models.MobileAccessory
@{
    ViewData["Title"] = "Accessory Details";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fa-solid fa-info-circle me-2"></i>Accessory Details</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="fa-solid fa-edit me-2"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left me-2"></i>Back to List
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="admin-card">
            <div class="row">
                <div class="col-md-5">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded border" style="width:100%;max-height:400px;object-fit:contain;" />
                    }
                    else
                    {
                        <div class="text-center p-5 bg-light rounded border">
                            <i class="fa-solid fa-image fa-5x text-muted"></i>
                            <p class="mt-3 text-muted">No image available</p>
                        </div>
                    }
                </div>
                <div class="col-md-7">
                    <h3 class="mb-3">@Model.Name</h3>

                    <div class="mb-3">
                        <span class="badge bg-info me-2">@Model.Brand</span>
                        @if (Model.Category != null)
                        {
                            <span class="badge bg-secondary">@Model.Category.Name</span>
                        }
                        @if (Model.IsFeatured)
                        {
                            <span class="badge bg-warning text-dark">
                                <i class="fa-solid fa-star me-1"></i>Featured
                            </span>
                        }
                    </div>

                    <div class="mb-4">
                        <h4 class="text-success mb-0">Rs @Model.Price.ToString("0.00")</h4>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <h6 class="text-muted mb-1">Stock Status</h6>
                            @if (Model.Stock > 0)
                            {
                                <span class="badge bg-success">@Model.Stock in stock</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Out of Stock</span>
                            }
                        </div>
                        <div class="col-6">
                            <h6 class="text-muted mb-1">Color</h6>
                            @if (!string.IsNullOrEmpty(Model.Color))
                            {
                                <p class="mb-0">@Model.Color</p>
                            }
                            else
                            {
                                <p class="mb-0 text-muted">Not specified</p>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Compatibility))
                    {
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Compatibility</h6>
                            <p class="mb-0">@Model.Compatibility</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Description</h6>
                            <p class="mb-0">@Model.Description</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="admin-card">
            <h5 class="mb-3"><i class="fa-solid fa-calendar me-2"></i>Details</h5>
            <dl class="row small mb-0">
                <dt class="col-sm-5">Accessory ID:</dt>
                <dd class="col-sm-7">#@Model.Id</dd>

                <dt class="col-sm-5">Created:</dt>
                <dd class="col-sm-7">@Model.CreatedAt.ToString("MMM dd, yyyy")</dd>

                @if (Model.UpdatedAt.HasValue)
                {
                    <dt class="col-sm-5">Last Updated:</dt>
                    <dd class="col-sm-7">@Model.UpdatedAt.Value.ToString("MMM dd, yyyy")</dd>
                }

                <dt class="col-sm-5">Stock Qty:</dt>
                <dd class="col-sm-7">@Model.Stock units</dd>

                <dt class="col-sm-5">Featured:</dt>
                <dd class="col-sm-7">
                    @if (Model.IsFeatured)
                    {
                        <span class="text-success">
                            <i class="fa-solid fa-check"></i> Yes
                        </span>
                    }
                    else
                    {
                        <span class="text-muted">No</span>
                    }
                </dd>
            </dl>
        </div>

        <div class="admin-card mt-3">
            <h5 class="mb-3"><i class="fa-solid fa-cog me-2"></i>Actions</h5>
            <div class="d-grid gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="fa-solid fa-edit me-2"></i>Edit Accessory
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                    <i class="fa-solid fa-trash me-2"></i>Delete Accessory
                </a>
            </div>
        </div>
    </div>
</div>
