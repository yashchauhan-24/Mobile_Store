@model IEnumerable<Mobile_Store.Models.Order>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="text-decoration-none">
            <div class="admin-card">
                <div class="d-flex align-items-center">
                    <div class="me-3"><i class="fa-solid fa-users fa-2x text-primary"></i></div>
                    <div>
                        <div class="small text-muted">Users</div>
                        <div class="h4 mb-0">@ViewBag.Users</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="text-decoration-none">
            <div class="admin-card">
                <div class="d-flex align-items-center">
                    <div class="me-3"><i class="fa-solid fa-box-open fa-2x text-primary"></i></div>
                    <div>
                        <div class="small text-muted">Products</div>
                        <div class="h4 mb-0">@ViewBag.Products</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="text-decoration-none">
            <div class="admin-card">
                <div class="d-flex align-items-center">
                    <div class="me-3"><i class="fa-solid fa-tags fa-2x text-primary"></i></div>
                    <div>
                        <div class="small text-muted">Categories</div>
                        <div class="h4 mb-0">@ViewBag.Categories</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="text-decoration-none">
            <div class="admin-card">
                <div class="d-flex align-items-center">
                    <div class="me-3"><i class="fa-solid fa-receipt fa-2x text-primary"></i></div>
                    <div>
                        <div class="small text-muted">Orders</div>
                        <div class="h4 mb-0">@ViewBag.Orders</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="admin-card">
    <h5 class="mb-3">Recent Orders</h5>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    <tr>
                        <td><strong>@o.Id</strong></td>
                        <td>@(o.User?.FullName ?? o.User?.Email ?? "N/A")</td>
                        <td>@o.OrderDate.ToLocalTime().ToString("MMM dd, yyyy")</td>
                        <td><strong>Rs @o.TotalAmount.ToString("0.00")</strong></td>
                        <td>
                            <span class="badge bg-@(o.Status == "Delivered" ? "success" : o.Status == "Cancelled" ? "danger" : "warning")">
                                @o.Status
                            </span>
                        </td>
                        <td>
                            <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-primary">
                                View Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
