@model IEnumerable<Mobile_Store.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Products</h3>
    <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="btn btn-primary">Add Product</a>
</div>

<div class="admin-card">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th style="width:200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><img src="@(string.IsNullOrEmpty(p.ImageUrl)? "/images/placeholder.png" : p.ImageUrl)" style="height:60px;width:60px;object-fit:cover;border-radius:4px;" alt="@p.Name" /></td>
                        <td>@p.Name</td>
                        <td>@p.Category?.Name</td>
                        <td><strong>$@p.Price.ToString("0.00")</strong></td>
                        <td>
                            <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-secondary">Edit</a>
                            <form asp-area="Admin" asp-controller="Products" asp-action="Delete" method="post" class="d-inline-block">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this product?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
